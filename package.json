{
  "name": "la-compagnia-della-ghironda",
  "version": "1.0.0",
  "description": "La Compagnia della Ghironda - A medieval fantasy guild website",
  "type": "module",
  "scripts": {
    "lint:html": "htmlhint index.html --config .htmlhintrc",
    "lint:css": "stylelint css/**/*.css",
    "lint:js": "eslint . --max-warnings=0 --cache --cache-location=.eslintcache",
    "lint": "npm run lint:html && npm run lint:css && npm run lint:js",
    "lint:parallel": "npm-run-all --parallel lint:html lint:css lint:js",
    "build": "npm run build:css && npm run build:js && npm run size-report",
    "build:css": "node build-css.js",
    "build:js": "node build-js.js",
    "prebuild": "npm run lint:parallel && npm run test:unit",
    "postbuild": "npm run audit:performance",
    "clean": "node -e \"const fs=require('fs'); try{fs.rmSync('dist',{recursive:true,force:true})}catch(e){}\"",
    "rebuild": "npm run clean && npm run build",
    "size-report": "node -e \"const fs = require('fs'); const css = fs.statSync('dist/style.min.css').size / 1024; const js = fs.statSync('dist/main.min.js').size / 1024; console.log('\\n=== Bundle Size Report ==='); console.log('CSS: ' + css.toFixed(2) + ' KB'); console.log('JS: ' + js.toFixed(2) + ' KB'); console.log('Total: ' + (css + js).toFixed(2) + ' KB\\n');\"",
    "generate:images": "node scripts/generate-images.js",
    "audit:security": "node scripts/security-audit.js",
    "audit:performance": "node scripts/performance-budget.js",
    "audit:all": "npm run audit:security && npm run audit:performance",
    "test:lint": "npm run lint",
    "test:lint:fast": "npm run lint:html && npm run lint:js --cache",
    "test:unit": "jest --coverage",
    "test:unit:fast": "jest --maxWorkers=2 --bail",
    "test:unit:watch": "jest --watch",
    "test:unit:ci": "jest --coverage --ci --maxWorkers=2",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:ci": "playwright test --workers=1",
    "test:accessibility": "playwright test tests/e2e/accessibility.spec.js",
    "test:mobile": "playwright test tests/e2e/mobile.spec.js",
    "test:mobile:headed": "playwright test tests/e2e/mobile.spec.js --headed",
    "audit:lighthouse:mobile": "lighthouse http://localhost:8000 --chrome-flags=\"--headless=new --disable-gpu\" --emulate-mobile-device --output-path=./test-results/lighthouse-mobile.json --output=json",
    "audit:lighthouse": "lighthouse http://localhost:8000 --chrome-flags=\"--headless=new --disable-gpu\" --output-path=./test-results/lighthouse.html --output=html",
    "audit:lighthouse:json": "lighthouse http://localhost:8000 --chrome-flags=\"--headless=new --disable-gpu\" --output=json --output-path=./test-results/lighthouse.json",
    "test": "npm run test:unit && npm run test:lint",
    "test:fast": "npm run test:unit:fast && npm run test:lint:fast",
    "test:all": "npm run test:unit && npm run test:lint && npm run test:e2e",
    "test:ci": "npm run test:unit:ci && npm run lint:parallel && npm run test:e2e:ci",
    "validate": "node scripts/validate.js",
    "validate:lighthouse": "node scripts/validate.js --lighthouse",
    "dev": "npm run clean && npm run test:fast",
    "prod": "npm run test:all && npm run build",
    "ci": "npm run test:ci && npm run build",
    "prepare": "husky install"
  },
  "keywords": [
    "medieval",
    "fantasy",
    "guild",
    "ultima-online",
    "single-page-application"
  ],
  "author": "La Compagnia della Ghironda",
  "license": "MIT",
  "lint-staged": {
    "index.html": "htmlhint --config .htmlhintrc",
    "css/**/*.css": "stylelint",
    "*.{js,mjs}": "eslint --max-warnings=0 --no-warn-ignored"
  },
  "devDependencies": {
    "@axe-core/cli": "^4.8.0",
    "@babel/preset-env": "^7.24.0",
    "@commitlint/config-conventional": "~20.5.0",
    "@playwright/test": "~1.59.1",
    "@testing-library/dom": "~10.4.1",
    "@testing-library/jest-dom": "~6.9.1",
    "axe-core": "~4.11.2",
    "axe-playwright": "~2.2.2",
    "babel-jest": "~30.3.0",
    "commitlint": "~20.5.0",
    "csso-cli": "^4.0.2",
    "eslint": "~10.2.0",
    "htmlhint": "^1.1.4",
    "http-server": "~14.1.1",
    "husky": "~9.1.7",
    "jest": "~30.3.0",
    "jest-environment-jsdom": "~30.3.0",
    "jsdom": "~27.0.1",
    "lighthouse": "~12.8.2",
    "lint-staged": "~16.4.0",
    "npm-run-all": "~4.1.5",
    "sharp": "~0.34.5",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0",
    "terser": "^5.46.1"
  }
}
