# npm Configuration
# Ottimizzazioni per la pipeline di build

# Usa latest npm, minor version per sicurezza
save-prefix=~

# Log verbosity (ridotto)
loglevel=warn

# Usa lock file (già in .gitignore)
package-lock=true

# Timeout per i download (ridotto, rete veloce)
fetch-timeout=20000

# Non salvare package-lock automaticamente (lo facciamo noi)
save-exact=false

# Maxsockets per parallelizzare i download
maxsockets=10
