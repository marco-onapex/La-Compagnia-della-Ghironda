{
  "extends": "stylelint-config-standard",
  "rules": {
    "selector-type-no-unknown": [
      true,
      {
        "ignoreTypes": [
          "/^math-/",
          "/^custom-/"
        ]
      }
    ],
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "supports"
        ]
      }
    ],
    "property-no-unknown": [
      true,
      {
        "ignoreProperties": [
          "/^mask/",
          "/^webkit-/",
          "/^moz-/"
        ]
      }
    ],
    "at-rule-descriptor-no-unknown": [
      true,
      {
        "ignoreDescriptors": [
          "orphans",
          "widows"
        ]
      }
    ]
  }
}
